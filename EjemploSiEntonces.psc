//Problema Si un número ingresado por el usuario es positivio o negativo
Algoritmo EjemploSiEntonces
	//Entrada
	Definir x Como Entero
	Escribir "Ingrese un número entero cualquiera por favor."
	Leer x
	//Proceso
	Si (x>=0) Entonces
		Escribir "El número es positivo"
	Sino 
		Escribir "El número es negativo."
	FinSi
	// Salida
FinAlgoritmo
